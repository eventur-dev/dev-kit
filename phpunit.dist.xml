<?xml version="1.0" encoding="UTF-8"?>

<phpunit
        backupGlobals="false"
        colors="true"
        failOnWarning="true"
        failOnRisky="true"
        failOnIncomplete="true"
        failOnSkipped="true"
>
    <php>
        <ini name="display_errors" value="1" />
        <ini name="error_reporting" value="-1" />
        <server name="APP_ENV" value="test" force="true" />
        <server name="SHELL_VERBOSITY" value="-1" />
    </php>
</phpunit>
